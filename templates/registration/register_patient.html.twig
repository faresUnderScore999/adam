{% extends 'base.html.twig' %}

{% block title %}Register a Patient - PsyCare{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">
        <div class="card">
            <div class="card-header">
                <h1 class="h4 mb-0">Join PsyCare as a Patient</h1>
            </div>
            <div class="card-body">
                <p class="text-muted mb-4">Create your account to connect with professional psychologists and start your mental health journey.</p>
                {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="row g-3">
                        <div class="col-md-6">
                            {{ form_label(registrationForm.firstName) }}
                            {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-control', 'placeholder': 'Enter your first name'}}) }}
                            {{ form_errors(registrationForm.firstName) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(registrationForm.lastName) }}
                            {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-control', 'placeholder': 'Enter your last name'}}) }}
                            {{ form_errors(registrationForm.lastName) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(registrationForm.email) }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'Enter your email address'}}) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(registrationForm.phone) }}
                            {{ form_widget(registrationForm.phone, {'attr': {'class': 'form-control', 'placeholder': 'Enter your phone number'}}) }}
                            {{ form_errors(registrationForm.phone) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(registrationForm.birthDate) }}
                            {{ form_widget(registrationForm.birthDate, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.birthDate) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(registrationForm.plainPassword.first) }}
                            {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder': 'Create a strong password'}}) }}
                            {{ form_errors(registrationForm.plainPassword.first) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(registrationForm.plainPassword.second) }}
                            {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirm your password'}}) }}
                            {{ form_errors(registrationForm.plainPassword.second) }}
                        </div>
                    </div>
                    <div class="mt-4">
                        {{ form_widget(registrationForm.save, {'attr': {'class': 'btn btn-primary w-100'}, 'label': 'Create Patient Account'}) }}
                    </div>
                {{ form_end(registrationForm) }}
                <div class="text-center mt-3">
                    <small class="text-muted">Already have an account? <a href="{{ path('app_login') }}">Sign in here</a></small>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
