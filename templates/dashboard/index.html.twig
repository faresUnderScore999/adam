{% extends 'base.html.twig' %}

{% block title %}Dashboard - PsyCare{% endblock %}

{% block body %}
<div class="row mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h4 mb-3">Welcome back, {{ app.user.firstName }}</h1>
                <p class="text-muted">Use your dashboard to review conversations and find the right psychologist.</p>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="card card-soft p-3">
                            <h2 class="h5">Messages</h2>
                            <p class="mb-0">{{ stats.totalMessages }} total messages in your inbox.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Search Psychologists</h2>
                {{ form_start(searchForm) }}
                    {{ form_row(searchForm.search) }}
                    <button class="btn btn-primary">Search</button>
                {{ form_end(searchForm) }}
            </div>
        </div>
    </div>
</div>

<div class="row">
    {% for psychologist in psychologists %}
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h3 class="h5">{{ psychologist.firstName }} {{ psychologist.lastName }}</h3>
                    <p class="mb-1"><strong>Specialty:</strong> {{ psychologist.specialty }}</p>
                    <p class="text-muted">{{ psychologist.bio|default('No bio provided.') }}</p>
                    <a class="btn btn-outline-primary btn-sm" href="{{ path('app_messages_new', {psychologistId: psychologist.id}) }}">Send message</a>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="alert alert-info">No psychologists match your search yet.</div>
        </div>
    {% endfor %}
</div>
{% endblock %}
