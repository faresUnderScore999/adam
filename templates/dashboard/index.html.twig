{% extends 'base.html.twig' %}

{% block title %}Dashboard - PsyCare{% endblock %}

{% block body %}
<div class="container">
    <div class="dashboard-grid">
        <div class="stat-card">
            <div class="icon">💬</div>
            <div class="number">{{ stats.totalMessages }}</div>
            <div class="label">Total Messages</div>
        </div>
        <div class="stat-card">
            <div class="icon">👥</div>
            <div class="number">{{ psychologists|length }}</div>
            <div class="label">Available Psychologists</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h2 class="h5 mb-0">Find Your Psychologist</h2>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        {% for psychologist in psychologists %}
                            <div class="col-md-6">
                                <div class="psychologist-card">
                                    <div class="psychologist-header">
                                        <div class="psychologist-name">{{ psychologist.firstName }} {{ psychologist.lastName }}</div>
                                        <div class="psychologist-specialty">{{ psychologist.specialty }}</div>
                                    </div>
                                    <div class="psychologist-body">
                                        <div class="psychologist-bio">{{ psychologist.bio|default('Professional psychologist ready to help you.') }}</div>
                                        <div class="mt-3">
                                            {% if isPatient %}
                                                <a class="btn btn-primary btn-sm w-100" href="{{ path('app_messages_new', {psychologistId: psychologist.id}) }}">Send Message</a>
                                            {% else %}
                                                <span class="text-muted small">Contact via patient account</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="col-12">
                                <div class="alert alert-info">No psychologists match your search criteria.</div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h2 class="h5 mb-0">Search Psychologists</h2>
                </div>
                <div class="card-body">
                    {{ form_start(searchForm) }}
                        <div class="mb-3">
                            {{ form_label(searchForm.search) }}
                            {{ form_widget(searchForm.search, {'attr': {'class': 'form-control', 'placeholder': 'Name or specialty'}}) }}
                        </div>
                        <button class="btn btn-primary w-100">{{ form_widget(searchForm.searchButton) }}</button>
                    {{ form_end(searchForm) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}