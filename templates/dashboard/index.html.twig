{% extends 'base.html.twig' %}

{% block title %}Dashboard - PsyCare{% endblock %}

{% block body %}
<!-- Page Header -->
<div class="mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h1 class="page-title mb-2">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </h1>
            <p class="text-muted">Welcome back! Here's what's happening with your account.</p>
        </div>
        <div class="col-auto">
            <a href="{{ path('app_messages') }}" class="btn btn-primary">
                <i class="bi bi-chat-left-dots me-2"></i>View Messages
            </a>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="dashboard-grid mb-5">
    <!-- Total Users Card -->
    <div class="stat-card">
        <div class="icon">👥</div>
        <div class="number">{{ totalUsers ?? 0 }}</div>
        <div class="label">Total Users</div>
    </div>

    <!-- Active Users Card -->
    <div class="stat-card">
        <div class="icon">✅</div>
        <div class="number">{{ activeUsers ?? 0 }}</div>
        <div class="label">Active Users</div>
    </div>

    <!-- Messages Card -->
    <div class="stat-card">
        <div class="icon">💬</div>
        <div class="number">{{ recentMessages|length }}</div>
        <div class="label">Recent Messages</div>
    </div>

    <!-- Status Card - Only show for admin users -->
    {% if is_granted('ROLE_ADMIN') and totalUsers > 0 %}
    <div class="stat-card">
        <div class="icon">📊</div>
        <div class="number">{{ (activeUsers / totalUsers * 100)|round }}%</div>
        <div class="label">Activity Rate</div>
    </div>
    {% endif %}
</div>

<!-- Content Grid -->
<div class="row g-4">
    <!-- Recent Messages Section -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="h5 mb-0">
                        <i class="bi bi-chat-dots me-2"></i>Recent Messages
                    </h2>
                </div>
                <a href="{{ path('app_messages') }}" class="btn btn-sm btn-outline-primary">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>

            {% if recentMessages|length > 0 %}
                <div class="card-body p-0">
                    {% for message in recentMessages|slice(0, 5) %}
                        <div class="message-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <div class="message-sender">
                                        <i class="bi bi-person-circle text-primary"></i>
                                        {{ message.sender.firstName }} {{ message.sender.lastName }}
                                        <span class="badge badge-primary ms-2">
                                            {{ message.sender.roles|first|replace({'ROLE_': ''})|lower }}
                                        </span>
                                    </div>
                                    <div class="message-preview">
                                        <strong>→ {{ message.receiver.firstName }} {{ message.receiver.lastName }}</strong>
                                    </div>
                                    <div class="message-preview mt-2">
                                        {{ message.content[:100] ~ (message.content|length > 100 ? '...' : '') }}
                                    </div>
                                </div>
                                <div class="text-end ms-3 flex-shrink-0">
                                    <div class="message-time">
                                        <i class="bi bi-clock me-1"></i>{{ message.createdAt|date('M j, H:i') }}
                                    </div>
                                    {% if message.isRead %}
                                        <small class="text-success"><i class="bi bi-check-all"></i> Read</small>
                                    {% else %}
                                        <small class="text-warning"><i class="bi bi-exclamation-circle"></i> Unread</small>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="card-body">
                    <div class="empty-state">
                        <div class="icon"><i class="bi bi-chat-dots text-muted"></i></div>
                        <h3>No messages yet</h3>
                        <p class="text-muted mb-3">Start a conversation to see messages here.</p>
                        <a href="{{ path('app_messages') }}" class="btn btn-primary">
                            <i class="bi bi-chat-dots me-2"></i>Start Messaging
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Quick Actions Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="h5 mb-0"><i class="bi bi-lightning me-2"></i>Quick Actions</h3>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('app_messages') }}" class="btn btn-outline-primary btn-sm text-start">
                        <i class="bi bi-chat-left-dots me-2"></i>View All Messages
                    </a>
                    <a href="{{ path('app_profile') }}" class="btn btn-outline-primary btn-sm text-start">
                        <i class="bi bi-person-circle me-2"></i>My Profile
                    </a>
                    <a href="{{ path('app_profile_edit') }}" class="btn btn-outline-primary btn-sm text-start">
                        <i class="bi bi-pencil-square me-2"></i>Edit Profile
                    </a>
                    {% if is_granted('ROLE_PATIENT') %}
                    <a href="#psychologist-search" class="btn btn-primary btn-sm text-start">
                        <i class="bi bi-search me-2"></i>Find Psychologist
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Statistics Card -->
        <div class="card">
            <div class="card-header">
                <h3 class="h5 mb-0"><i class="bi bi-graph-up me-2"></i>Quick Stats</h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Platform Health</span>
                        <span class="badge badge-success">Excellent</span>
                    </div>
                    <div class="progress" role="progressbar" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 95%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">User Engagement</span>
                        <span class="text-primary fw-600">85%</span>
                    </div>
                    <div class="progress" role="progressbar" style="height: 6px;">
                        <div class="progress-bar bg-primary" style="width: 85%"></div>
                    </div>
                </div>

                <div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Message Delivery</span>
                        <span class="text-success fw-600">99%</span>
                    </div>
                    <div class="progress" role="progressbar" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 99%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Psychologist Search Section for Patients -->
{% if is_granted('ROLE_PATIENT') %}
<div id="psychologist-search" class="mt-5">
    <div class="card">
        <div class="card-header">
            <h2 class="h5 mb-0">
                <i class="bi bi-search me-2"></i>Find a Psychologist
            </h2>
            <small class="text-muted">Search by name or specialty to start a conversation</small>
        </div>
        <div class="card-body">
            {{ form_start(searchForm, {'attr': {'class': 'mb-4'}}) }}
                <div class="input-group">
                    {{ form_widget(searchForm.search, {'attr': {'class': 'form-control', 'placeholder': 'Search psychologists...'}}) }}
                    <button class="btn btn-primary" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            {{ form_end(searchForm) }}

            {% if psychologists|length > 0 %}
                <div class="row g-3">
                    {% for psychologist in psychologists %}
                        <div class="col-md-6">
                            <div class="card psychologist-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="avatar-circle me-3">
                                            {{ (psychologist.firstName|slice(0, 1)|upper) }}{{ (psychologist.lastName|slice(0, 1)|upper) }}
                                        </div>
                                        <div>
                                            <h6 class="mb-0">{{ psychologist.firstName }} {{ psychologist.lastName }}</h6>
                                            <small class="text-muted">{{ psychologist.specialty }}</small>
                                        </div>
                                    </div>
                                    <a href="{{ path('app_messages_new', {'psychologistId': psychologist.id}) }}" class="btn btn-primary btn-sm w-100">
                                        <i class="bi bi-chat-dots me-2"></i>Start Conversation
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% elseif searchForm.search.vars.submitted %}
                <div class="text-center py-4">
                    <i class="bi bi-search text-muted" style="font-size: 2rem;"></i>
                    <p class="text-muted mt-2">No psychologists found matching your search.</p>
                </div>
            {% else %}
                <div class="text-center py-4">
                    <i class="bi bi-people text-muted" style="font-size: 2rem;"></i>
                    <p class="text-muted mt-2">Search for psychologists to start a conversation.</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}

<!-- Admin Section (if applicable) -->
{% if is_granted('ROLE_ADMIN') %}
    <div class="mt-5">
        <div class="alert alert-info bg-light border-0">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <i class="bi bi-shield-lock me-2"></i>
                    <strong>Admin Panel Available</strong>
                    <br>
                    <small class="text-muted">Manage users and system settings</small>
                </div>
                <div>
                    <a href="{{ path('admin_dashboard') }}" class="btn btn-sm btn-primary">
                        Access Admin <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endif %}

<style>
    .page-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--gray-900);
        position: relative;
        display: inline-block;
    }

    .page-title::after {
        content: '';
        position: absolute;
        bottom: -8px;
        left: 0;
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, #4f46e5, #0ea5e9);
        border-radius: 9999px;
    }

    .empty-state {
        text-align: center;
        padding: 2rem;
        color: #6b7280;
    }

    .empty-state .icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    .empty-state h3 {
        font-size: 1.25rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.5rem;
    }
</style>
{% endblock %}
