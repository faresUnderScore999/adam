{% extends 'base.html.twig' %}

{% block title %}My Profile - PsyCare{% endblock %}

{% block body %}
<div class="profile-header">
    <div class="profile-avatar">
        <i class="bi bi-person-fill"></i>
    </div>
    <div class="profile-name">{{ user.firstName }} {{ user.lastName }}</div>
    <div class="profile-role">{{ user.isPsychologist() ? 'Psychologist' : 'Patient' }}</div>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h2 class="h5 mb-0">Profile Information</h2>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <strong class="text-muted">Email</strong>
                <div>{{ user.email }}</div>
            </div>
            <div class="col-md-6">
                <strong class="text-muted">Phone</strong>
                <div>{{ user.phone }}</div>
            </div>
            <div class="col-md-6">
                <strong class="text-muted">Birth Date</strong>
                <div>{{ user.birthDate ? user.birthDate|date('F j, Y') : 'Not provided' }}</div>
            </div>
            <div class="col-md-6">
                <strong class="text-muted">Account Status</strong>
                <div><span class="badge bg-success">Active</span></div>
            </div>
            {% if user.isPsychologist() %}
                <div class="col-md-6">
                    <strong class="text-muted">Specialty</strong>
                    <div>{{ user.specialty }}</div>
                </div>
                <div class="col-md-6">
                    <strong class="text-muted">Diploma</strong>
                    <div>{{ user.diploma }}</div>
                </div>
                <div class="col-12">
                    <strong class="text-muted">Biography</strong>
                    <div class="mt-2">{{ user.bio|nl2br }}</div>
                </div>
            {% endif %}
        </div>
        <div class="mt-4">
            <a class="btn btn-primary" href="{{ path('app_profile_edit') }}">
                <i class="bi bi-pencil"></i> Edit Profile
            </a>
        </div>
    </div>
</div>
{% endblock %}
