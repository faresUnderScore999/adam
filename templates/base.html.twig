<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>{% block title %}PsyCare - Mental Health Platform{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  

</head>
<body>
    <!-- Navigation -->
    {% if app.request.attributes.get('_route') != 'app_messages_conversation' %}
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
        <div class="container-lg">
            <!-- Brand -->
            <a class="navbar-brand" href="{{ path('app_dashboard') }}">
                <i class="bi bi-heart-pulse-fill me-2"></i>
                <span class="fw-700">PsyCare</span>
            </a>

            <!-- Navbar Toggler -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navbar Content -->
            <div class="collapse navbar-collapse" id="navbarNav">
                {% if app.user %}
                    <!-- Main Navigation -->
                    <ul class="navbar-nav ms-auto me-4 mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_dashboard') }}">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_messages') }}">
                                <i class="bi bi-chat-left-dots me-1"></i>Messages
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_profile') }}">
                                <i class="bi bi-person-circle me-1"></i>Profile
                            </a>
                        </li>
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-600" href="{{ path('admin_dashboard') }}">
                                    <i class="bi bi-shield-lock me-1"></i>Admin
                                </a>
                            </li>
                        {% endif %}
                    </ul>

                    <!-- User Dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-light dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i>
                            <span class="d-none d-md-inline">{{ app.user.firstName }}</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">{{ app.user.firstName }} {{ app.user.lastName }}</h6></li>
                            <li><small class="dropdown-header text-muted">{{ app.user.roles|first }}</small></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{{ path('app_profile') }}"><i class="bi bi-person me-2"></i>My Profile</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_profile_edit') }}"><i class="bi bi-pencil me-2"></i>Edit Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                {% else %}
                    <!-- Auth Links -->
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_login') }}">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-sm btn-primary ms-2" href="{{ path('app_register_patient') }}">Get Started</a>
                        </li>
                    </ul>
                {% endif %}
            </div>
        </div>
    </nav>
    {% endif %}

    <!-- Main Content -->
    <main class="main-content">
        <div class="container-lg">
            <!-- Alerts -->
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show mt-4" role="alert">
                        <div class="d-flex align-items-start gap-3">
                            {% if label == 'success' %}
                                <i class="bi bi-check-circle-fill text-success flex-shrink-0 mt-1"></i>
                            {% elseif label == 'error' %}
                                <i class="bi bi-exclamation-circle-fill text-danger flex-shrink-0 mt-1"></i>
                            {% elseif label == 'warning' %}
                                <i class="bi bi-exclamation-triangle-fill text-warning flex-shrink-0 mt-1"></i>
                            {% else %}
                                <i class="bi bi-info-circle-fill text-info flex-shrink-0 mt-1"></i>
                            {% endif %}
                            <div>{{ message }}</div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- Page Content -->
            {% block body %}{% endblock %}
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer mt-auto py-5 border-top">
        <div class="container-lg">
            <div class="row g-4">
                <div class="col-md-6">
                    <h6 class="fw-700 mb-3"><i class="bi bi-heart-pulse-fill me-2 text-primary"></i>PsyCare</h6>
                    <p class="text-muted small">Connecting patients with mental health professionals for secure, confidential conversations.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <small class="text-muted">
                        <p class="mb-1">&copy; {{ "now"|date('Y') }} PsyCare. All rights reserved.</p>
                        <p class="mb-0">Built with care for your mental health.</p>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Navbar scroll enhancement
        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar');
            navbar.classList.toggle('navbar-scrolled', window.scrollY > 50);
        });

        // Auto-hide alerts after 5 seconds
        document.querySelectorAll('.alert').forEach(alert => {
            setTimeout(() => {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }, 5000);
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
