{% extends 'base.html.twig' %}

{% block title %}Login - PsyCare{% endblock %}

{% block body %}
<div class="row justify-content-center align-items-center" style="min-height: calc(100vh - 300px);">
    <div class="col-lg-5 col-md-6">
        <!-- Login Card -->
        <div class="card border-0">
            <!-- Header -->
            <div class="card-header border-0 text-center py-4">
                <div class="mb-3">
                    <i class="bi bi-heart-pulse-fill" style="font-size: 2.5rem; color: #4f46e5;"></i>
                </div>
                <h1 class="h3 mb-2 fw-700">Welcome Back</h1>
                <p class="text-muted mb-0">Sign in to continue to PsyCare</p>
            </div>

            <!-- Body -->
            <div class="card-body py-4">
                <!-- Error Alert -->
                {% if error %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        <strong>Login Failed</strong>
                        <br>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endif %}

                <!-- Login Form -->
                <form method="post" action="{{ path('app_login') }}" class="needs-validation">
                    <!-- Email Field -->
                    <div class="form-group">
                        <label for="username" class="form-label">
                            <i class="bi bi-envelope me-2"></i>Email Address
                        </label>
                        <input 
                            type="email" 
                            id="username" 
                            name="_username" 
                            class="form-control form-control-lg"
                            value="{{ last_username }}"
                            placeholder="you@example.com"
                            required 
                            autofocus
                        >
                    </div>

                    <!-- Password Field -->
                    <div class="form-group">
                        <label for="password" class="form-label">
                            <i class="bi bi-lock me-2"></i>Password
                        </label>
                        <input 
                            type="password" 
                            id="password" 
                            name="_password" 
                            class="form-control form-control-lg"
                            placeholder="••••••••"
                            required
                        >
                    </div>

                    <!-- Remember Me -->
                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" id="remember" name="_remember_me">
                        <label class="form-check-label" for="remember">
                            Keep me signed in
                        </label>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </button>
                </form>

                <!-- Divider -->
                <div class="position-relative mb-4">
                    <hr>
                    <span class="position-absolute top-50 start-50 translate-middle bg-white px-2 text-muted small">or</span>
                </div>

                <!-- Registration Links -->
                <div class="d-grid gap-2">
                    <a href="{{ path('app_register_patient') }}" class="btn btn-outline-primary btn-lg">
                        <i class="bi bi-person-plus me-2"></i>Register as Patient
                    </a>
                    <a href="{{ path('app_register_psychologist') }}" class="btn btn-outline-primary btn-lg">
                        <i class="bi bi-briefcase me-2"></i>Register as Psychologist
                    </a>
                </div>
            </div>

            <!-- Footer -->
            <div class="card-footer border-0 bg-light text-center py-3">
                <small class="text-muted">
                    Don't have an account? 
                    <a href="{{ path('app_register_patient') }}" class="fw-600">Get started</a>
                </small>
            </div>
        </div>

        <!-- Security Note -->
        <div class="mt-4 alert alert-info bg-light border-0 text-center">
            <i class="bi bi-shield-check text-info me-2"></i>
            <small>Your information is encrypted and secure</small>
        </div>
    </div>
</div>
{% endblock %}
