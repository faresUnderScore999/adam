{% extends 'base.html.twig' %}

{% block title %}Conversations - PsyCare{% endblock %}

{% block body %}
<div class="container">
    <div class="card">
        <div class="card-header">
            <h1 class="h4 mb-0">📬 My Conversations</h1>
        </div>
        <div class="card-body p-0">
            {% for item in conversations %}
                <a href="{{ path('app_messages_conversation', { partnerId: item.id }) }}" class="text-decoration-none">
                    <div class="message-item {% if item.unread_count > 0 %}unread{% endif %}">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="message-sender">
                                    {{ item.first_name }} {{ item.last_name }}
                                    {% if item.specialty %}
                                        <span class="badge bg-secondary ms-2">{{ item.specialty }}</span>
                                    {% endif %}
                                </div>
                                <div class="message-preview">{{ item.preview }}</div>
                            </div>
                            <div class="text-end">
                                <div class="message-time">{{ item.last_at|date('M j, H:i') }}</div>
                                {% if item.unread_count > 0 %}
                                    <span class="badge bg-primary mt-1">{{ item.unread_count }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </a>
            {% else %}
                <div class="alert alert-info m-3">You have no conversations yet. Start by messaging a psychologist from your dashboard.</div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}