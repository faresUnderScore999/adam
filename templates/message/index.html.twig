{% extends 'base.html.twig' %}

{% block title %}Messages - PsyCare{% endblock %}

{% block body %}
<div class="row g-0" style="min-height: calc(100vh - 200px);">
    <!-- Messages List Sidebar -->
    <div class="col-lg-4 border-end">
        <!-- Header -->
        <div class="p-4 border-bottom">
            <h2 class="h5 mb-3 fw-700">
                <i class="bi bi-chat-dots me-2"></i>Messages
            </h2>
            <div class="input-group input-group-sm">
                <input 
                    type="text" 
                    class="form-control" 
                    placeholder="Search conversations..."
                    id="searchMessages"
                >
                <button class="btn btn-outline-secondary" type="button">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>

        <!-- Messages List -->
        <div class="list-group list-group-flush">
            {% if conversations|length > 0 %}
                {% for conversation in conversations %}
                    <a 
                        href="{{ path('app_messages_conversation', {partnerId: conversation.id}) }}"
                        class="list-group-item list-group-item-action message-item {% if conversation.unreadCount > 0 %}unread{% endif %}"
                    >
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <div 
                                    class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                    style="width: 40px; height: 40px; font-weight: 600;"
                                >
                                    {{ (conversation.otherUser.firstName|slice(0, 1)|upper) }}{{ (conversation.otherUser.lastName|slice(0, 1)|upper) }}
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-600">
                                        {{ conversation.otherUser.firstName }} {{ conversation.otherUser.lastName }}
                                    </h6>
                                    <small class="text-muted">
                                        {{ conversation.otherUser.roles|first|replace({'ROLE_': ''})|lower }}
                                    </small>
                                </div>
                            </div>
                            {% if conversation.unreadCount > 0 %}
                                <span class="badge bg-primary rounded-pill">{{ conversation.unreadCount }}</span>
                            {% endif %}
                        </div>
                        <div class="message-preview text-muted small">
                            {{ conversation.lastMessage.content[:50] ~ (conversation.lastMessage.content|length > 50 ? '...' : '') }}
                        </div>
                        <div class="message-time text-muted small">
                            {{ conversation.lastMessage.createdAt|date('M j, H:i') }}
                        </div>
                    </a>
                {% endfor %}
            {% else %}
                <div class="p-4 text-center text-muted">
                    <div class="mb-3">
                        <i class="bi bi-chat-left-dots" style="font-size: 3rem; opacity: 0.3;"></i>
                    </div>
                    <p>No conversations yet</p>
                    <small>Start a conversation to begin messaging</small>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Conversation View -->
    <div class="col-lg-8">
        {% if currentConversation %}
            <div class="conversation-container">
                <!-- Conversation Header -->
                <div class="border-bottom p-4 bg-light">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div 
                                class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                style="width: 50px; height: 50px; font-weight: 600;"
                            >
                                {{ (currentConversation.otherUser.firstName|slice(0, 1)|upper) }}{{ (currentConversation.otherUser.lastName|slice(0, 1)|upper) }}
                            </div>
                            <div>
                                <h5 class="mb-0 fw-600">{{ currentConversation.otherUser.firstName }} {{ currentConversation.otherUser.lastName }}</h5>
                                <small class="text-muted">
                                    <i class="bi bi-circle-fill text-success" style="font-size: 0.4rem;"></i>
                                    Online
                                </small>
                            </div>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-info-circle me-2"></i>View Profile</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-bell me-2"></i>Mute Notifications</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-trash me-2"></i>Delete Conversation</a></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Messages Area -->
                <div class="conversation-messages">
                    {% if messages|length > 0 %}
                        {% for message in messages %}
                            <div class="mb-3">
                                <div class="d-flex {% if message.sender == app.user %}justify-content-end{% else %}justify-content-start{% endif %}">
                                    <div 
                                        class="message-bubble {% if message.sender == app.user %}sent{% else %}received{% endif %}"
                                    >
                                        {{ message.content }}
                                        <div class="mt-2 {% if message.sender == app.user %}text-end{% endif %}">
                                            <small class="{% if message.sender == app.user %}text-white-50{% else %}text-muted{% endif %}">
                                                {{ message.createdAt|date('H:i') }}
                                                {% if message.sender == app.user and message.isRead %}
                                                    <i class="bi bi-check-all ms-1 text-white"></i>
                                                {% endif %}
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                    <div id="messagesEnd"></div>
                </div>

                <!-- Input Area -->
                <div class="conversation-input">
                    <form method="post" action="{{ path('app_send_message') }}" class="d-flex gap-2">
                        <input 
                            type="hidden" 
                            name="receiver_id" 
                            value="{{ currentConversation.otherUser.id }}"
                        >
                        <input 
                            type="text" 
                            class="form-control form-control-lg"
                            name="content"
                            placeholder="Type your message..."
                            id="messageInput"
                            required
                        >
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send"></i>
                        </button>
                    </form>
                </div>
            </div>

            <script>
                // Auto-scroll to bottom
                document.getElementById('messagesEnd').scrollIntoView();
                
                // Focus input
                document.getElementById('messageInput').focus();
            </script>
        {% else %}
            <!-- Empty State -->
            <div class="h-100 d-flex align-items-center justify-content-center">
                <div class="text-center">
                    <i class="bi bi-chat-dots" style="font-size: 4rem; color: #e5e7eb;"></i>
                    <h3 class="mt-4 text-muted">Select a conversation</h3>
                    <p class="text-muted">Choose a conversation from the list to start messaging</p>
                </div>
            </div>
        {% endif %}
    </div>
</div>

<style>
    .conversation-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 200px);
        background: white;
    }

    .conversation-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
    }

    .conversation-input {
        padding: 1.5rem;
        border-top: 1px solid #e5e7eb;
        background: #f9fafb;
    }

    .message-bubble {
        padding: 0.875rem 1.25rem;
        border-radius: 1rem;
        max-width: 70%;
        word-wrap: break-word;
        animation: fadeInUp 0.3s ease;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .message-bubble.sent {
        background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
        color: white;
        border-bottom-right-radius: 0.25rem;
    }

    .message-bubble.received {
        background: #f3f4f6;
        color: #1f2937;
        border-bottom-left-radius: 0.25rem;
    }

    @media (max-width: 991px) {
        .col-lg-4 {
            display: none;
        }
        
        .message-bubble {
            max-width: 85%;
        }
    }
</style>
{% endblock %}
